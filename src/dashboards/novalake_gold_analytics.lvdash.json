{
  "datasets": [
    {
      "name": "095b31d6",
      "displayName": "ds_transaction_volume",
      "queryLines": [
        "select\r\n",
        "    date_trunc('DAY', event_date) as day,\r\n",
        "    source,\r\n",
        "    currency_clean,\r\n",
        "    transaction_count,\r\n",
        "    completed_count,\r\n",
        "    gross_amount_major\r\n",
        "from novalake.gold.metric_transaction_volume"
      ]
    },
    {
      "name": "2d224aae",
      "displayName": "ds_approval_decline_trend",
      "queryLines": [
        "select\r\n",
        "    date_trunc('DAY', m.event_date) as day,\r\n",
        "    m.source,\r\n",
        "    m.completed_count,\r\n",
        "    m.failed_count,\r\n",
        "    m.approval_rate,\r\n",
        "    m.decline_rate\r\n",
        "from novalake.gold.metric_approval_decline_rate m"
      ]
    },
    {
      "name": "2802c30f",
      "displayName": "ds_approval_decline_rollup",
      "queryLines": [
        "with latest as (\r\n",
        "    select max(date_day) as max_date from novalake.gold.dim_date\r\n",
        ")\r\n",
        "select\r\n",
        "    sum(completed_count) / nullif(sum(completed_count) + sum(failed_count), 0) as approval_rate_qtd\r\n",
        "from novalake.gold.metric_approval_decline_rate m\r\n",
        "join novalake.gold.dim_date d on m.event_date = d.date_day\r\n",
        "cross join latest l\r\n",
        "where d.year = year(l.max_date) and d.quarter = quarter(l.max_date)"
      ]
    },
    {
      "name": "c76abda2",
      "displayName": "ds_refund_rate_by_source",
      "queryLines": [
        "select\r\n",
        "    source,\r\n",
        "    sum(refund_count) as refund_count,\r\n",
        "    sum(completed_transaction_count) as completed_transaction_count,\r\n",
        "    sum(refund_count) / nullif(sum(completed_transaction_count), 0) as refund_rate\r\n",
        "from novalake.gold.metric_refund_rate\r\n",
        "group by source"
      ]
    },
    {
      "name": "96a83a39",
      "displayName": "ds_payout_latency",
      "queryLines": [
        "select\r\n",
        "    date_trunc('DAY', event_date) as day,\r\n",
        "    source,\r\n",
        "    schedule_status,\r\n",
        "    payout_count,\r\n",
        "    avg_lead_days,\r\n",
        "    p50_lead_days,\r\n",
        "    p90_lead_days\r\n",
        "from novalake.gold.metric_payout_latency"
      ]
    },
    {
      "name": "3094275b",
      "displayName": "ds_support_resolution_time (ndjson only)",
      "queryLines": [
        "select priority, avg(resolution_minutes) as avg_resolution_minutes\r\n",
        "from novalake.gold.fct_support_tickets\r\n",
        "where source = 'ndjson' and resolved = true\r\n",
        "group by priority"
      ]
    },
    {
      "name": "3f098b0a",
      "displayName": "ds_support_sla_breach_rate (multiline only)",
      "queryLines": [
        "select\r\n",
        "    priority,\r\n",
        "    sum(breached_count) as breached_count,\r\n",
        "    sum(ticket_count) as ticket_count,\r\n",
        "    sum(breached_count) / nullif(sum(ticket_count), 0) as sla_breach_rate\r\n",
        "from novalake.gold.metric_support_sla_breach_rate_multiline\r\n",
        "group by priority"
      ]
    },
    {
      "name": "1c671bd2",
      "displayName": "ds_fraud_signals",
      "queryLines": [
        "select\r\n",
        "    source,\r\n",
        "    sum(risk_flagged_count) / nullif(sum(transaction_count), 0) as txn_risk_flagged_rate,\r\n",
        "    sum(auto_blocked_count) / nullif(sum(alert_count), 0) as alert_auto_block_rate\r\n",
        "from novalake.gold.metric_fraud_signals\r\n",
        "group by source"
      ]
    },
    {
      "name": "cb1c9ccc",
      "displayName": "ds_ratings_by_category",
      "queryLines": [
        "select\r\n",
        "    m.category,\r\n",
        "    sum(r.avg_rating * r.rating_count) / nullif(sum(r.rating_count), 0) as avg_rating,\r\n",
        "    sum(r.rating_count) as rating_count\r\n",
        "from novalake.gold.metric_review_ratings_by_merchant r\r\n",
        "join novalake.gold.dim_merchants m on r.merchant_id = m.merchant_id\r\n",
        "group by m.category"
      ]
    },
    {
      "name": "8241c508",
      "displayName": "ds_auth_success_rate",
      "queryLines": [
        "select\r\n",
        "    mfa_used,\r\n",
        "    count(*) filter (where result = 'success') / nullif(count(*), 0) as success_rate,\r\n",
        "    count(*) as session_count\r\n",
        "from novalake.gold.fct_auth_sessions\r\n",
        "group by mfa_used"
      ]
    },
    {
      "name": "59fb18aa",
      "displayName": "ds_kyc_status_share",
      "queryLines": [
        "select\r\n",
        "    source,\r\n",
        "    status,\r\n",
        "    count(*) as verification_count,\r\n",
        "    count(*) / sum(count(*)) over (partition by source) as status_share\r\n",
        "from novalake.gold.fct_kyc_verifications\r\n",
        "group by source, status"
      ]
    }
  ],
